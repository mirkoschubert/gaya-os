// This is the Prisma schema for gaya-os.
// Domain models are defined here. Better Auth tables are appended via `pnpm dlx @better-auth/cli generate`.
// To switch to Postgres for production: change `provider` to "postgresql" here and in src/lib/server/auth.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// DOMAIN ENUMS
// ──────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum CivicStatus {
  VISITOR
  CITIZEN
}

enum MembershipRole {
  MEMBER
  COUNCIL_MEMBER
}

enum DocumentType {
  CONSTITUTION
  POLICY
  PROCEDURE
}

enum DocumentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProposalCategory {
  CONSTITUTION
  BUDGET
  GOVERNANCE
  CULTURE
  OTHER
}

enum ProposalStatus {
  DISCUSSION
  READY_FOR_VOTE
  VOTING
  ACCEPTED
  REJECTED
}

enum VoteType {
  POLL
  DECISION
  ELECTION
}

enum VoteChoice {
  YES
  NO
  ABSTAIN
}

enum DelegationCategory {
  GLOBAL
  CONSTITUTION
  BUDGET
  GOVERNANCE
  CULTURE
}

// ──────────────────────────────────────────────
// DOMAIN MODELS
// Note: The `user` model is generated by Better Auth (see below).
// Domain-specific fields (role, civicStatus, citizenId, joinedAt) are declared
// as additionalFields in src/lib/server/auth.ts and added to Better Auth's user table.
// ──────────────────────────────────────────────

model Unit {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  memberships Membership[]
  councils    Council[]
  proposals   Proposal[]
  budgets     Budget[]
}

model Membership {
  id       String         @id @default(cuid())
  userId   String
  unitId   String
  role     MembershipRole @default(MEMBER)
  joinedAt DateTime       @default(now())

  unit Unit @relation(fields: [unitId], references: [id])

  @@unique([userId, unitId])
}

model Council {
  id        String   @id @default(cuid())
  unitId    String
  name      String
  createdAt DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id])
}

model Document {
  id        String            @id @default(cuid())
  title     String
  type      DocumentType
  slug      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  versions  DocumentVersion[]
}

model DocumentVersion {
  id           String         @id @default(cuid())
  documentId   String
  versionLabel String
  content      String
  status      DocumentStatus @default(DRAFT)
  changelog   String?
  createdAt   DateTime       @default(now())
  createdById String?

  document    Document       @relation(fields: [documentId], references: [id])
  createdBy   user?          @relation(fields: [createdById], references: [id])

  @@unique([documentId, versionLabel])
  @@index([documentId, status])
}

model Proposal {
  id        String           @id @default(cuid())
  title     String
  body      String
  category  ProposalCategory
  status    ProposalStatus   @default(DISCUSSION)
  unitId    String?
  authorId  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  unit        Unit?             @relation(fields: [unitId], references: [id])
  supports    ProposalSupport[]
  comments    Comment[]
  voteSession VoteSession?
}

model ProposalSupport {
  id         String   @id @default(cuid())
  proposalId String
  userId     String
  createdAt  DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id])

  @@unique([proposalId, userId])
}

model Comment {
  id         String   @id @default(cuid())
  proposalId String
  authorId   String
  body       String
  createdAt  DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id])
}

model VoteSession {
  id         String   @id @default(cuid())
  proposalId String   @unique
  type       VoteType
  startsAt   DateTime
  endsAt     DateTime
  createdAt  DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id])
  votes    Vote[]
}

model Vote {
  id            String     @id @default(cuid())
  voteSessionId String
  voterId       String
  choice        VoteChoice
  createdAt     DateTime   @default(now())

  voteSession VoteSession @relation(fields: [voteSessionId], references: [id])

  @@unique([voteSessionId, voterId])
}

model Delegation {
  id          String             @id @default(cuid())
  delegatorId String
  delegateId  String
  category    DelegationCategory
  createdAt   DateTime           @default(now())

  @@unique([delegatorId, category])
}

model Budget {
  id        String   @id @default(cuid())
  unitId    String
  year      Int
  amount    Int
  createdAt DateTime @default(now())

  unit     Unit            @relation(fields: [unitId], references: [id])
  projects BudgetProject[]
}

model BudgetProject {
  id          String   @id @default(cuid())
  budgetId    String
  title       String
  description String
  cost        Int
  createdAt   DateTime @default(now())

  budget Budget @relation(fields: [budgetId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user user? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}

model SystemSetting {
  key         String   @id
  value       Json
  updatedAt   DateTime @updatedAt
  updatedById String?

  updatedBy user? @relation(fields: [updatedById], references: [id])
}

model RoleCapability {
  id         String  @id @default(cuid())
  role       String
  capability String
  allowed    Boolean @default(false)

  @@unique([role, capability])
  @@index([role])
}

// ──────────────────────────────────────────────
// BETTER AUTH TABLES
// Generated by Better Auth. Do not edit manually.
// ──────────────────────────────────────────────

model user {
  id          String    @id
  name        String
  email       String    @unique
  emailVerified Boolean
  image       String?
  createdAt   DateTime
  updatedAt   DateTime
  // Identity additionalFields
  firstName       String  @default("")
  lastName        String  @default("")
  // Username plugin fields (managed by better-auth)
  username        String? @unique
  displayUsername String?
  // Domain additionalFields
  role        String    @default("USER")
  civicStatus String    @default("VISITOR")
  citizenId   String?   @unique
  joinedAt    DateTime?
  lastLogin   DateTime?
  // Profile additionalFields
  bio         String?
  location    String?
  links       Json?
  avatarUrl   String?
  heroUrl     String?
  showRealName Boolean  @default(true)

  sessions         session[]
  accounts         account[]
  passkeys         passkey[]
  auditLogs        AuditLog[]
  documentVersions DocumentVersion[]
  systemSettings   SystemSetting[]
}

model session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@unique([identifier, value])
}

model passkey {
  id                   String    @id
  name                 String?
  publicKey            String
  userId               String
  credentialID         String    @unique
  counter              Int
  deviceType           String
  backedUp             Boolean
  transports           String?
  createdAt            DateTime?
  aaguid               String?

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}
