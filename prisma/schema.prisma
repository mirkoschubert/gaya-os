// This is the Prisma schema for gaya-os.
// Domain models are defined here. Better Auth tables are appended via `pnpm dlx @better-auth/cli generate`.
// To switch to Postgres for production: change `provider` to "postgresql" here and in src/lib/server/auth.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// DOMAIN ENUMS
// ──────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum CivicStatus {
  VISITOR
  CITIZEN
}

enum MembershipRole {
  MEMBER
  COUNCIL_MEMBER
}

enum CouncilType {
  NATIONAL
  REGIONAL
  THEMATIC
}

enum CouncilSessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AgendaItemStatus {
  OPEN
  IN_DISCUSSION
  RESOLVED
  DEFERRED
}

enum NominationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum InternalVoteStatus {
  OPEN
  CLOSED
}

enum InternalVoteChoice {
  YES
  NO
  ABSTAIN
}

enum ChannelType {
  COUNCIL_INTERNAL
  CITIZEN_GENERAL  // The global citizen channel - always open, not closeable
  COUNCIL_PUBLIC   // Contact-a-council group DM - closeable by non-council members
  DIRECT_MESSAGE   // 1:1 DM - closeable
}

enum MessageReactionType {
  THUMBS_UP
  THUMBS_DOWN
  QUESTION
}

enum DocumentType {
  CONSTITUTION
  POLICY
  PROCEDURE
}

enum DocumentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProposalCategory {
  CONSTITUTION
  BUDGET
  GOVERNANCE
  CULTURE
  OTHER
}

enum ProposalStatus {
  DISCUSSION
  READY_FOR_VOTE
  VOTING
  ACCEPTED
  REJECTED
}

enum VoteType {
  POLL
  DECISION
  ELECTION
}

enum VoteChoice {
  YES
  NO
  ABSTAIN
}

enum DelegationCategory {
  GLOBAL
  CONSTITUTION
  BUDGET
  GOVERNANCE
  CULTURE
}

// ──────────────────────────────────────────────
// DOMAIN MODELS
// Note: The `user` model is generated by Better Auth (see below).
// Domain-specific fields (role, civicStatus, citizenId, joinedAt) are declared
// as additionalFields in src/lib/server/auth.ts and added to Better Auth's user table.
// ──────────────────────────────────────────────

model Unit {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  memberships Membership[]
  councils    Council[]
  proposals   Proposal[]
  budgets     Budget[]
}

model Membership {
  id       String         @id @default(cuid())
  userId   String
  unitId   String
  role     MembershipRole @default(MEMBER)
  joinedAt DateTime       @default(now())

  user user @relation(fields: [userId], references: [id])
  unit Unit @relation(fields: [unitId], references: [id])

  @@unique([userId, unitId])
}

model Council {
  id               String      @id @default(cuid())
  unitId           String      @unique
  name             String
  type             CouncilType
  scopeDescription String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  unit             Unit                    @relation(fields: [unitId], references: [id])
  sessions         CouncilSession[]
  nominations      CandidateNomination[]
  internalVotes    InternalVote[]
  representatives  CouncilRepresentative[]
  channels         Channel[]
}

model CouncilSession {
  id          String               @id @default(cuid())
  councilId   String
  title       String
  description String?
  scheduledAt DateTime
  endsAt      DateTime?
  status      CouncilSessionStatus @default(SCHEDULED)
  location    String?
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  council     Council              @relation(fields: [councilId], references: [id])
  agendaItems CouncilAgendaItem[]

  @@index([councilId, scheduledAt])
}

model CouncilAgendaItem {
  id          String           @id @default(cuid())
  sessionId   String
  title       String
  description String?
  status      AgendaItemStatus @default(OPEN)
  order       Int              @default(0)
  proposalId  String?
  outcome     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  session  CouncilSession @relation(fields: [sessionId], references: [id])
  proposal Proposal?      @relation(fields: [proposalId], references: [id])

  @@index([sessionId, order])
}

model CouncilRepresentative {
  id        String    @id @default(cuid())
  councilId String
  userId    String
  area      String
  since     DateTime  @default(now())
  until     DateTime?

  council Council @relation(fields: [councilId], references: [id])
  user    user    @relation(fields: [userId], references: [id])

  @@index([councilId])
}

model CandidateNomination {
  id            String           @id @default(cuid())
  councilId     String
  candidateId   String
  nominatedById String?
  voteSessionId String?
  status        NominationStatus @default(PENDING)
  statement     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  council     Council      @relation(fields: [councilId], references: [id])
  voteSession VoteSession? @relation(fields: [voteSessionId], references: [id])

  @@unique([councilId, candidateId, voteSessionId])
  @@index([councilId, status])
}

model InternalVote {
  id          String             @id @default(cuid())
  councilId   String
  title       String
  description String?
  status      InternalVoteStatus @default(OPEN)
  endsAt      DateTime?
  outcome     String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  council  Council          @relation(fields: [councilId], references: [id])
  ballots  InternalBallot[]
  messages Message[]

  @@index([councilId, status])
}

model InternalBallot {
  id             String             @id @default(cuid())
  internalVoteId String
  voterId        String
  choice         InternalVoteChoice
  createdAt      DateTime           @default(now())

  internalVote InternalVote @relation(fields: [internalVoteId], references: [id])

  @@unique([internalVoteId, voterId])
}

model Channel {
  id        String      @id @default(cuid())
  councilId String?
  type      ChannelType @default(COUNCIL_INTERNAL)
  name      String?
  createdAt DateTime    @default(now())

  council  Council?            @relation(fields: [councilId], references: [id])
  messages Message[]
  members  ChannelMembership[]
  mutes    ChannelMute[]

  @@index([councilId])
}

model ChannelMembership {
  id         String    @id @default(cuid())
  channelId  String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?
  hiddenAt   DateTime? // set when user "closes" a closeable channel

  channel Channel @relation(fields: [channelId], references: [id])
  user    user    @relation(fields: [userId], references: [id])

  @@unique([channelId, userId])
}

model Message {
  id             String    @id @default(cuid())
  channelId      String
  authorId       String
  body           String
  editedAt       DateTime?
  deletedAt      DateTime?
  pinned         Boolean   @default(false)
  internalVoteId String?
  createdAt      DateTime  @default(now())

  channel      Channel           @relation(fields: [channelId], references: [id])
  author       user              @relation(fields: [authorId], references: [id])
  internalVote InternalVote?     @relation(fields: [internalVoteId], references: [id])
  reactions    MessageReaction[]

  @@index([channelId, createdAt])
}

model ChannelMute {
  id        String    @id @default(cuid())
  channelId String
  userId    String
  mutedById String
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  channel Channel @relation(fields: [channelId], references: [id])
  user    user    @relation("ChannelMuteTarget", fields: [userId], references: [id])
  mutedBy user    @relation("ChannelMutedBy", fields: [mutedById], references: [id])

  @@unique([channelId, userId])
}

model MessageReaction {
  id        String              @id @default(cuid())
  messageId String
  userId    String
  type      MessageReactionType
  createdAt DateTime            @default(now())

  message Message @relation(fields: [messageId], references: [id])
  user    user    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, type])
}

model Document {
  id        String            @id @default(cuid())
  title     String
  type      DocumentType
  slug      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  versions  DocumentVersion[]
}

model DocumentVersion {
  id           String         @id @default(cuid())
  documentId   String
  versionLabel String
  content      String
  status      DocumentStatus @default(DRAFT)
  changelog   String?
  createdAt   DateTime       @default(now())
  createdById String?

  document    Document       @relation(fields: [documentId], references: [id])
  createdBy   user?          @relation(fields: [createdById], references: [id])

  @@unique([documentId, versionLabel])
  @@index([documentId, status])
}

model Proposal {
  id                  String           @id @default(cuid())
  title               String
  body                String
  category            ProposalCategory
  status              ProposalStatus   @default(DISCUSSION)
  unitId              String?
  authorId            String
  reviewedByCouncilId String?
  reviewNote          String?
  reviewedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  unit        Unit?               @relation(fields: [unitId], references: [id])
  supports    ProposalSupport[]
  comments    Comment[]
  voteSession VoteSession?
  agendaItems CouncilAgendaItem[]
}

model ProposalSupport {
  id         String   @id @default(cuid())
  proposalId String
  userId     String
  createdAt  DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id])

  @@unique([proposalId, userId])
}

model Comment {
  id         String   @id @default(cuid())
  proposalId String
  authorId   String
  body       String
  createdAt  DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id])
}

model VoteSession {
  id         String   @id @default(cuid())
  proposalId String   @unique
  type       VoteType
  startsAt   DateTime
  endsAt     DateTime
  createdAt  DateTime @default(now())

  proposal    Proposal              @relation(fields: [proposalId], references: [id])
  votes       Vote[]
  nominations CandidateNomination[]
}

model Vote {
  id            String     @id @default(cuid())
  voteSessionId String
  voterId       String
  choice        VoteChoice
  createdAt     DateTime   @default(now())

  voteSession VoteSession @relation(fields: [voteSessionId], references: [id])

  @@unique([voteSessionId, voterId])
}

model Delegation {
  id          String             @id @default(cuid())
  delegatorId String
  delegateId  String
  category    DelegationCategory
  createdAt   DateTime           @default(now())

  @@unique([delegatorId, category])
}

model Budget {
  id        String   @id @default(cuid())
  unitId    String
  year      Int
  amount    Int
  createdAt DateTime @default(now())

  unit     Unit            @relation(fields: [unitId], references: [id])
  projects BudgetProject[]
}

model BudgetProject {
  id          String   @id @default(cuid())
  budgetId    String
  title       String
  description String
  cost        Int
  createdAt   DateTime @default(now())

  budget Budget @relation(fields: [budgetId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user user? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}

model SystemSetting {
  key         String   @id
  value       Json
  updatedAt   DateTime @updatedAt
  updatedById String?

  updatedBy user? @relation(fields: [updatedById], references: [id])
}

model RoleCapability {
  id         String  @id @default(cuid())
  role       String
  capability String
  allowed    Boolean @default(false)

  @@unique([role, capability])
  @@index([role])
}

// ──────────────────────────────────────────────
// CITIZENSHIP MODELS
// ──────────────────────────────────────────────

enum CitizenshipStatus {
  PENDING
  APPROVED
  REJECTED
}

model CitizenshipApplication {
  id             String            @id @default(cuid())
  userId         String            @unique
  firstName      String
  middleNames    String?
  lastName       String
  country        String
  city           String?
  motivationText String
  status         CitizenshipStatus @default(PENDING)
  flags          Json?             // ApplicationFlag[]
  ipAddress      String?           // Snapshot zum Zeitpunkt der Bewerbung
  userAgent      String?
  fingerprintId  String?           // reserviert für spätere Nutzung
  geoCountry     String?           // für spätere IP-Geo-Auflösung
  reviewerId     String?
  reviewedAt     DateTime?
  reviewComment  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user     user  @relation("CitizenshipApplicant", fields: [userId], references: [id], onDelete: Cascade)
  reviewer user? @relation("CitizenshipReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([ipAddress, createdAt(sort: Desc)])
}

// Zentrale technische Profildaten — für laufendes Monitoring nach Einbürgerung.
// Wird bei Application-Submit und (falls verfügbar) beim Login aktualisiert.
model UserTechnicalProfile {
  userId         String   @id
  registrationIp String?  // einmalig beim ersten Antrag, nie überschrieben
  lastIp         String?
  lastUserAgent  String?
  ipHistory      Json?    // Array<{ ip: string, seenAt: string }>, max. 50 Einträge
  countries      Json?    // Array<string> abgeleiteter Ländercodes (für VPN-Erkennung)
  updatedAt      DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserFlag {
  id        String   @id @default(cuid())
  userId    String
  code      String   // z.B. "MULTI_ACCOUNT_SUSPECT", "GEO_COUNTRY_MISMATCH"
  metadata  Json?    // z.B. { sourceApplicationId, ip, detectedCountries }
  createdAt DateTime @default(now())

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// ──────────────────────────────────────────────
// USERNAME MODELS
// ──────────────────────────────────────────────

// Patterns (exact words or regex) that are forbidden as usernames.
// Managed via Admin UI, stored in DB.
model UsernameBlacklist {
  id          String   @id @default(cuid())
  pattern     String   @unique // exact word or regex string, case-insensitive
  reason      String?
  createdAt   DateTime @default(now())
  createdById String?

  createdBy user? @relation(fields: [createdById], references: [id], onDelete: SetNull)
}

// Tracks every username change for cooldown enforcement and audit purposes.
model UsernameChangeLog {
  id          String   @id @default(cuid())
  userId      String
  oldUsername String
  newUsername String
  changedAt   DateTime @default(now())

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt(sort: Desc)])
}

// ──────────────────────────────────────────────
// BETTER AUTH TABLES
// Generated by Better Auth. Do not edit manually.
// ──────────────────────────────────────────────

model user {
  id          String    @id
  name        String
  email       String    @unique
  emailVerified Boolean
  image       String?
  createdAt   DateTime
  updatedAt   DateTime
  // Identity additionalFields
  firstName       String  @default("")
  lastName        String  @default("")
  // Username plugin fields (managed by better-auth)
  username        String? @unique
  displayUsername String?
  // Domain additionalFields
  role        String    @default("USER")
  civicStatus String    @default("VISITOR")
  citizenId   String?   @unique
  joinedAt    DateTime?
  lastLogin   DateTime?
  // Profile additionalFields
  bio         String?
  location    String?
  links       Json?
  avatarUrl   String?
  heroUrl     String?
  showRealName Boolean  @default(true)

  sessions         session[]
  accounts         account[]
  passkeys         passkey[]
  auditLogs        AuditLog[]
  documentVersions DocumentVersion[]
  systemSettings   SystemSetting[]

  citizenshipApplication CitizenshipApplication?  @relation("CitizenshipApplicant")
  reviewedApplications   CitizenshipApplication[] @relation("CitizenshipReviewer")
  technicalProfile       UserTechnicalProfile?
  userFlags              UserFlag[]
  usernameChanges        UsernameChangeLog[]
  usernameBlacklists     UsernameBlacklist[]
  memberships            Membership[]
  councilRepresentatives CouncilRepresentative[]
  channelMemberships     ChannelMembership[]
  messages               Message[]
  messageReactions       MessageReaction[]
  channelMutesReceived   ChannelMute[]           @relation("ChannelMuteTarget")
  channelMutesMade       ChannelMute[]           @relation("ChannelMutedBy")
}

model session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@unique([identifier, value])
}

model passkey {
  id                   String    @id
  name                 String?
  publicKey            String
  userId               String
  credentialID         String    @unique
  counter              Int
  deviceType           String
  backedUp             Boolean
  transports           String?
  createdAt            DateTime?
  aaguid               String?

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}
