{
	"name": "gaya-os",
	"private": true,
	"version": "0.5.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "prisma migrate deploy && prisma generate && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"postinstall": "prisma generate",
		"release": "zsh scripts/release.sh",
		"db:studio": "prisma studio",
		"db:migrate": "prisma migrate dev",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tanstack/table-core": "^8.21.3",
		"@types/diff": "^8.0.0",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.18.0",
		"@vitest/browser-playwright": "^4.1.0",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"dotenv": "^17.3.1",
		"formsnap": "^2.0.1",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prisma": "^7.5.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"sveltekit-superforms": "^2.30.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"pnpm": {
		"peerDependencyRules": {
			"ignoreMissing": [
				"better-sqlite3",
				"@react-email/render",
				"pg-native",
				"cloudflare:sockets"
			]
		}
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"dependencies": {
		"@better-auth/passkey": "^1.5.5",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.40.0",
		"@prisma/adapter-pg": "^7.5.0",
		"@prisma/client": "^7.5.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@thumbmarkjs/thumbmarkjs": "^1.7.5",
		"@uiw/codemirror-theme-tokyo-night": "^4.25.8",
		"@vercel/analytics": "^2.0.1",
		"@vercel/blob": "^2.3.1",
		"@vercel/speed-insights": "^2.0.0",
		"better-auth": "^1.5.5",
		"countries-list": "^3.3.0",
		"diff": "^8.0.3",
		"marked": "^17.0.4",
		"pg": "^8.20.0",
		"resend": "^6.9.3",
		"svelte-codemirror-editor": "^2.1.0",
		"tailwindcss": "^4.2.1"
	}
}
