# Better Auth
BETTER_AUTH_SECRET=
# BETTER_AUTH_URL is no longer needed — derived automatically from VERCEL_URL (production)
# or defaults to http://localhost:5173 (local development).

# First admin user (set to your email before first login)
ADMIN_EMAIL=

# PUBLIC_APP_URL is no longer needed — the auth client uses the current origin automatically.

# Resend (Email)
RESEND_API_KEY=re_...
# Without a verified domain: leave empty to use onboarding@resend.dev (Resend test mode)
# Emails in test mode can only be delivered to your Resend account email address.
RESEND_FROM_EMAIL=

# Vercel Blob (Profile picture & banner uploads)
# Get from: Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Citizenship Debug Mode
# Enables relaxed throttling and skips account-age checks for testing with multiple accounts.
# NEVER set to true in production — the service enforces this regardless of the env var.
CITIZENSHIP_DEBUG=false

# Prisma / Database
# Development (SQLite) — used by prisma/schema.prisma (local only):
DATABASE_URL="file:./prisma/dev.db"
# Production (Postgres via Neon) — set automatically by Vercel's Neon integration:
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
