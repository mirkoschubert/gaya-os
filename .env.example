# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173

# First admin user (set to your email before first login)
ADMIN_EMAIL=

# Public (safe to expose to browser)
PUBLIC_APP_URL=http://localhost:5173

# Resend (Email)
RESEND_API_KEY=re_...
# Without a verified domain: leave empty to use onboarding@resend.dev (Resend test mode)
# Emails in test mode can only be delivered to your Resend account email address.
# With a verified domain: set to e.g. "Gaya OS <noreply@yourdomain.com>"
RESEND_FROM_EMAIL=

# Prisma / Database
# Development (SQLite):
DATABASE_URL="file:./prisma/dev.db"
# Production (Postgres):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
